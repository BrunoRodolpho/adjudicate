{
  "name": "adjudicate",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-trust runtime for LLM intent execution",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"@adjudicate/*\" build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@adjudicate/eslint-config": "workspace:*",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
