# adjudicate console — runtime configuration
#
# Copy this file to `.env.local` and uncomment the lines you need.
# Next.js inlines NEXT_PUBLIC_* vars at build time; restart `pnpm dev`
# after changes.

# Client-side gateway mode.
#   "mock" (default): client reads ALL_MOCKS in-process. Static demo.
#   "live"          : client hits /api/admin/trpc through the @adjudicate/
#                     admin-sdk router. Verifies the full wire contract.
# NEXT_PUBLIC_ADJUDICATE_MODE=live

# Postgres connection string for the durable AuditStore + governance log.
# When set, the SDK route handler swaps in @adjudicate/audit-postgres-backed
# stores. When unset, the route handler falls back to in-memory mocks.
#
# Apply migrations 001-004 from packages/audit-postgres/migrations/ before
# starting the console with this set.
# DATABASE_URL=postgres://user:password@localhost:5432/adjudicate

# Redis coordination (Phase 1.5d) — closes the loop between the Console
# and the kernel runtime. When BOTH `REDIS_URL` and `EMERGENCY_REDIS_KEY`
# are set, Console toggles write to the same Redis key the kernel's
# `startDistributedKillSwitch` polls. Every replica converges within ~1s.
# The kernel must be running its `startDistributedKillSwitch` poller
# against the same key for the loop to close end-to-end.
#
# Without these, live emergency state is volatile and console-local —
# toggles do not affect the kernel runtime.
# REDIS_URL=redis://localhost:6379
# EMERGENCY_REDIS_KEY=adjudicate:kill-switch

# Coordination indicator — mirrors the server-side `EMERGENCY_REDIS_KEY`
# setting so the panel renders the correct sync indicator. Set together
# with the server-side env vars as a deployment checklist item.
#   "in-memory" (default): amber "not coordinated" notice
#   "redis"              : emerald "synced with kernel" indicator
# NEXT_PUBLIC_ADJUDICATE_EMERGENCY_COORDINATION=redis
