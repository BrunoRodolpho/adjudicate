{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "incremental": true,
    "allowJs": false,
    "isolatedModules": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": ".next/types",
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@adjudicate/core": ["../../packages/core/src/index.ts"],
      "@adjudicate/core/kernel": ["../../packages/core/src/kernel/index.ts"],
      "@adjudicate/core/llm": ["../../packages/core/src/llm/index.ts"],
      "@adjudicate/core/*": ["../../packages/core/src/*"],
      "@adjudicate/audit": ["../../packages/audit/src/index.ts"],
      "@adjudicate/audit/*": ["../../packages/audit/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
